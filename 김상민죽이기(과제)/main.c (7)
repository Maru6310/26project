    void set_color(int code) {
        HANDLE hConsole = GetStdHandle(STD_OUTPUT_HANDLE);
        SetConsoleTextAttribute(hConsole, code);
    }

    int move_cursor(int x, int y) {
        HANDLE hConsole = GetStdHandle(STD_OUTPUT_HANDLE);
        COORD pos = { (SHORT)(x - 1), (SHORT)(y - 1) };
        SetConsoleCursorPosition(hConsole, pos);
        return 0;
    }

    void print_colored_map(const wchar_t* map) {
        HANDLE hConsole = GetStdHandle(STD_OUTPUT_HANDLE);
        WORD redText = FOREGROUND_RED | FOREGROUND_INTENSITY;
        WORD blackText = 0;
        WORD originalColor = FOREGROUND_RED | FOREGROUND_GREEN | FOREGROUND_BLUE;

        for (int i = 0; map[i] != L'\0'; i++) {
            if (map[i] == L'□') {
                SetConsoleTextAttribute(hConsole, blackText);
                wprintf(L"□");
            }
            else if (map[i] == L'■') {
                SetConsoleTextAttribute(hConsole, redText);
                wprintf(L"■");
            }
            else {
                SetConsoleTextAttribute(hConsole, originalColor);
                wprintf(L"%c", map[i]);
            }
        }
        SetConsoleTextAttribute(hConsole, originalColor);
    }

    int ProcessRunMode() 
    {
        char input_str[20] = { 0 };
        while (1) {
            system("cls"); // 화면 지우기

            set_color(FONT_COLOR_RED);
            move_cursor(15, 24);
            printf("정말로 도망치시겠습니까? 'Run'을 입력하고 엔터를 누르세요. (No: 돌아가기): ");

            // 입력 대기 (이곳에서 게임 로직은 완전히 멈춥니다)
            set_color(FONT_COLOR_RED);
            move_cursor(90, 24);
            scanf("%s", input_str);

            if (strcmp(input_str, "Run") == 0) {
                return 2; // 도망 성공
            }
            else if (strcmp(input_str, "No") == 0) {
                return 0; // 취소
            }
            else {
                move_cursor(15, 26);
                set_color(FONT_COLOR_RED);
                printf("잘못 입력했습니다! 'Run'을 정확하게 입력하세요.");
                Sleep(1500);
            }
        }
    }

