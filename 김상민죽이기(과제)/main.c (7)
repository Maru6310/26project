    int sleep_or_skip(int ms) {
        int interval = 50;
        int elapsed = 0;
        while (elapsed < ms)
        {
            if (_kbhit())
            {
                while (_kbhit()) _getch();
                return 1;
            }
            Sleep(interval);
            elapsed += interval;
        }
        return 0;
    }

